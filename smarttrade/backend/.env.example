NODE_ENV=development
PORT=4000

# Database — PostgreSQL 16
DATABASE_URL=postgresql://user:password@localhost:5432/smarttrade_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — RS256 key pair, generate with: npm run generate:keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_HASH=choose-a-long-random-secret

# SMTP (e.g. Mailtrap for dev, a real provider for prod)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@smarttrade.africa

# Cloudinary (https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Monitoring (optional)
SENTRY_DSN=

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# WebAuthn (biometric login)
RP_ID=
RP_NAME=

