    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@simplewebauthn/browser": "^10.0.0",
    "@tanstack/react-query": "^5.17.15",
    "axios": "^1.6.7",
    "clsx": "^2.1.0",
    "i18next": "^23.7.19",
    "js-cookie": "^3.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
